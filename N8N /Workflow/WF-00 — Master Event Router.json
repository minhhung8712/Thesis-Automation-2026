    },
    {
      "parameters": {
        "jsCode": "// ===== WF-00: Parse & Normalize + Classify =====\n// Forwarder syslog->HTTP da POST JSON vao webhook nay.\n// Code ho tro ca khi du lieu nam trong .body hoac o goc.\n\n// Map event_type cu the -> nhom handler\nconst ROUTE_MAP = {\n  IDS_ALERT: 'WF-01',\n  PORT_SCAN: 'WF-01',\n  BRUTE_FORCE: 'WF-01',\n  HIGH_BANDWIDTH: 'WF-02',\n  CONN_FLOOD: 'WF-02',\n  NEW_MAC: 'WF-03',\n  UNKNOWN_DEVICE: 'WF-03',\n  VPN_TUNNEL_DOWN: 'WF-04',\n};\n\nconst out = [];\nfor (const item of $input.all()) {\n  const input = item.json.body ?? item.json;\n  const eventType = (input.event_type || '').toString().toUpperCase();\n  const route = ROUTE_MAP[eventType] || 'DISCARD';\n\n  out.push({\n    json: {\n      event_id: input.event_id || `evt-${Date.now()}-${Math.floor(Math.random() * 1000)}`,\n      timestamp: input.timestamp || new Date().toISOString(),\n      src_ip: input.src_ip || null,\n      dst_ip: input.dst_ip || null,\n      protocol: input.protocol || null,\n      event_type: eventType,\n      severity: (input.severity || '').toString().toUpperCase() || null,\n      site: input.site || null,\n      raw: input,\n      route: route,\n    },\n  });\n}\nreturn out;"
      },
      "id": "a1b2c3d4-0002-4002-8002-000000000002",
      "name": "Parse & Normalize",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [480, 320]
    },
    {
