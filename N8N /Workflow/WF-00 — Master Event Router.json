                "conditions": [
                  { "leftValue": "={{ $json.route }}", "rightValue": "WF-01", "operator": { "type": "string", "operation": "equals" } }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "WF-01 IP Attack"
            },
