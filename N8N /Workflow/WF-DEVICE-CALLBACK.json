      "id": "c1000000-0013-0000-0000-000000000013",
      "name": "Extract Pending (cb)",
      "type": "n8n-nodes-base.extractFromFile",
      "typeVersion": 1,
      "position": [
        1420,
        300
      ],
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "// APPROVE: chon IP trong dai 192.168.12.11 - 192.168.12.199 (bo cac IP da cap),\n// tra hostname tu pending, chuan bi dong ghi approved_macs.txt + text sua tin nhan.\nconst approvedTxt = $('Extract Approved (cb)').first()?.json?.data || '';\nconst pendingTxt  = $('Extract Pending (cb)').first()?.json?.data || '';\nconst info = $('Parse Callback').first().json;\nconst mac  = info.mac;\n\n// IP da su dung\nconst used = new Set();\nfor (const l of approvedTxt.split('\\n')) {\n  const p = l.split(',');\n  if (p[1] && p[1].trim()) used.add(p[1].trim());\n}\n// chon IP trong dau tien\nlet ip = null;\nfor (let i = 11; i <= 199; i++) {\n  const cand = '192.168.12.' + i;\n  if (!used.has(cand)) { ip = cand; break; }\n}\n// hostname tu pending\nlet hostname = '';\nfor (const l of pendingTxt.split('\\n')) {\n  const p = l.split(',');\n  if ((p[0] || '').trim().toLowerCase() === mac) { hostname = (p[1] || '').trim(); break; }\n}\n\nif (!ip) {\n  return [{ json: { ...info, hostname, ip: null,\n    edit_text: '\\u26A0\\uFE0F KHONG THE APPROVE ' + mac + '\\nHet IP trong trong dai 12.11-12.199.' }}];\n}\nreturn [{ json: {\n  ...info, ip, hostname,\n  approved_line: mac + ',' + ip + ',' + hostname + '\\n',\n  edit_text: '\\u2705 DA APPROVE\\nMAC: ' + mac + '\\nIP: ' + ip +\n             '\\nHostname: ' + (hostname || '(khong ro)') + '\\nBoi: ' + info.by\n}}];\n"
      },
      "id": "c1000000-0014-0000-0000-000000000014",
      "name": "Pick Free IP",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1620,
        300
      ]
    },
