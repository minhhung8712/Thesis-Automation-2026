      "id": "c1000000-0001-0000-0000-000000000001",
      "name": "On Button Press",
      "type": "n8n-nodes-base.telegramTrigger",
      "typeVersion": 1.1,
      "position": [
        160,
        460
      ],
      "webhookId": "cb00cb00-cb00-4cb0-8cb0-cb00cb00cb00"
    },
    {
      "parameters": {
        "jsCode": "// Tach callback_data cua nut bam: dinh dang \"approve|<mac>\" / \"reject|<mac>\"\nconst cq = $json.callback_query || {};\nconst data = cq.data || '';\nconst idx = data.indexOf('|');\nconst action = (idx >= 0 ? data.slice(0, idx) : data).toLowerCase();\nconst mac    = (idx >= 0 ? data.slice(idx + 1) : '').toLowerCase();\nreturn [{ json: {\n  action, mac,\n  callback_query_id: cq.id,\n  chat_id: cq.message?.chat?.id,\n  message_id: cq.message?.message_id,\n  by: cq.from?.username || cq.from?.first_name || 'admin'\n}}];\n"
      },
      "id": "c1000000-0002-0000-0000-000000000002",
      "name": "Parse Callback",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        380,
        460
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "loose",
            "version": 2
          },
          "conditions": [
            {
              "leftValue": "={{ $json.action }}",
              "rightValue": "approve",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "c1000000-0003-0000-0000-000000000003",
      "name": "APPROVE?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        600,
        460
      ]
    },
